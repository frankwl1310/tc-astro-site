    </a>
    <p class="text-[14px] font-semibold text-white">Taipan Consulting GmbH</p>
    <address class="text-[16px] not-italic text-white leading-relaxed">
      Neue Mainzer Str. 66<br />
      60311 Frankfurt
    </address>
    <p class="text-[16px]">
      <a href="tel:+496994322134" class="text-white hover:opacity-90 transition-opacity">+49 69 94322134</a>
    </p>
    <p class="text-[16px]">
      <a href="mailto:fwl@taipanconsulting.de" class="text-white hover:opacity-90 transition-opacity">fwl@taipanconsulting.de</a>
    </p>
    <div class="pt-6 border-t border-taipan-blue-800 text-[14px] text-white flex flex-wrap gap-x-4 gap-y-1">
