---
const navItems = [
  { label: "Diagnose", href: "/#diagnose" },
  { label: "Arbeitsweise", href: "/arbeitsweise" },
  { label: "HubSpot How-to", href: "/hubspot-how-to" },
  { label: "Warum HubSpot-Projekte scheitern", href: "/warum-hubspot-projekte-scheitern" },
  { label: "Entlastung", href: "/operative-entlastung-in-der-praxis" },
  { label: "Über", href: "/ueber-taipan-consulting" },
];
---
<nav class="fixed top-0 left-0 right-0 z-50 bg-taipan-blue-900" aria-label="Hauptnavigation">
  <div class="w-full section-padding flex items-center justify-between h-16">
    <a href="/" class="flex items-center h-10">
      <img src="/taipan-logo.png" alt="TAIPAN Consulting" width="180" height="40" class="h-8 w-auto object-contain" />
    </a>

    <div class="hidden md:flex items-center gap-8">
      {navItems.map((item) => (
        <a
          key={item.href}
          href={item.href}
          class="text-[14px] font-medium text-taipan-gray-500 hover:text-white transition-colors duration-200"
        >
          {item.label}
        </a>
      ))}
      <a
        href="/gespraech"
        class="h-10 px-6 inline-flex items-center bg-taipan-orange text-white rounded-md text-[14px] font-semibold hover:bg-taipan-orange-hover transition-colors duration-200"
      >
        Gespräch
      </a>
    </div>

    <button
      type="button"
      class="md:hidden text-white p-2"
      id="nav-toggle"
      aria-label="Menü öffnen"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path class="nav-icon-open" d="M4 6h16M4 12h16M4 18h16" />
        <path class="nav-icon-close hidden" d="M6 6l12 12M6 18L18 6" />
      </svg>
    </button>
  </div>

  <div class="md:hidden hidden bg-taipan-blue-900 section-padding pb-6 border-t border-taipan-blue-800" id="nav-dropdown">
    {navItems.map((item) => (
      <a key={item.href} href={item.href} class="block py-3 text-[14px] font-medium text-taipan-gray-500 hover:text-white transition-colors nav-mobile-link">
        {item.label}
      </a>
    ))}
    <a href="/gespraech" class="mt-3 h-10 px-6 inline-flex items-center bg-taipan-orange text-white rounded-md text-[14px] font-semibold nav-mobile-link">
      Gespräch
    </a>
  </div>
</nav>

<script>
  (function () {
    const toggle = document.getElementById("nav-toggle");
    const dropdown = document.getElementById("nav-dropdown");
    if (!toggle || !dropdown) return;
    const openIcon = toggle.querySelector(".nav-icon-open");
    const closeIcon = toggle.querySelector(".nav-icon-close");

    toggle.addEventListener("click", () => {
      const isOpen = !dropdown.classList.contains("hidden");
      dropdown.classList.toggle("hidden", isOpen);
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Menü öffnen" : "Menü schließen");
      if (openIcon) openIcon.classList.toggle("hidden", !isOpen);
      if (closeIcon) closeIcon.classList.toggle("hidden", isOpen);
    });

    dropdown.querySelectorAll(".nav-mobile-link").forEach((link) => {
      link.addEventListener("click", () => {
        dropdown.classList.add("hidden");
        toggle?.setAttribute("aria-expanded", "false");
        toggle?.setAttribute("aria-label", "Menü öffnen");
        if (openIcon) openIcon.classList.remove("hidden");
        if (closeIcon) closeIcon.classList.add("hidden");
      });
    });
  })();
</script>
