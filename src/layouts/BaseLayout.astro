---
import "../styles/global.css";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
}
const { title = "Taipan Consulting – HubSpot, das im Alltag wirklich entlastet", description = "HubSpot wird eingeführt, um Arbeit zu vereinfachen. In vielen Unternehmen passiert das Gegenteil." } = Astro.props;
---
<!DOCTYPE html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <slot name="head" />
  </head>
  <body class="min-h-screen bg-white">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
