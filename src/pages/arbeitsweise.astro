---
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://taipanconsulting.de/" },
    { "@type": "ListItem", "position": 2, "name": "Arbeitsweise", "item": "https://taipanconsulting.de/arbeitsweise/" },
  ],
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "Arbeitsweise – Taipan Consulting",
  "description": "Wir starten nicht mit HubSpot. Wir starten mit Arbeit. Unser Ansatz: Geschäftslogik vor System, Transformation durch Entlastung.",
  "url": "https://taipanconsulting.de/arbeitsweise/",
  "isPartOf": { "@type": "WebSite", "name": "Taipan Consulting", "url": "https://taipanconsulting.de/" },
  "provider": { "@type": "ProfessionalService", "name": "Taipan Consulting GmbH", "url": "https://taipanconsulting.de" },
};
---
<BaseLayout
  title="Arbeitsweise – Taipan Consulting"
  description="Wir starten nicht mit HubSpot. Wir starten mit Arbeit. Unser Ansatz: Geschäftslogik vor System, Transformation durch Entlastung."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  </Fragment>
  <!-- Typ A – Weiß: Hero -->
  <section class="section-a section-padding pt-28 pb-20 md:pt-32 md:pb-24">
    <div class="max-w-content mx-auto">
      <h1 class="max-w-3xl mb-6">Arbeitsweise</h1>
      <h2 class="max-w-3xl mb-6 text-2xl font-semibold">
        Wir starten nicht mit HubSpot.
        <span class="text-taipan-blue-600"> Wir starten mit Arbeit.</span>
      </h2>
      <p class="text-body max-w-prose mb-5">
        In vielen HubSpot-Projekten beginnt die Zusammenarbeit mit einem Setup, einer Tool-Auswahl oder einer Feature-Diskussion.
      </p>
      <p class="text-body max-w-prose mb-5">
        Unser Ansatz ist ein anderer.
      </p>
      <p class="text-body max-w-prose">
        Wir gehen davon aus, dass Systeme keine Probleme lösen, sondern bestehende Arbeitsweisen sichtbar machen.
        Deshalb beginnen wir nicht bei HubSpot, sondern bei der Geschäftslogik, die im Alltag gelebt wird.
      </p>
    </div>
  </section>

  <!-- Typ B – Dunkel: Ausgangspunkt -->
  <section class="section-b section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Ausgangspunkt: Geschäftslogik vor System</h2>
      <p class="max-w-prose mb-6 text-[18px] leading-[1.75]">
        Im Zentrum unserer Arbeit steht immer die Frage:
      </p>
      <p class="max-w-prose mb-8 text-[18px] leading-[1.75] font-semibold text-taipan-blue-100">
        Welche Arbeit wird heute von wem erledigt – und warum?
      </p>
      <p class="max-w-prose mb-5 text-[18px] leading-[1.75]">
        Erst wenn klar ist,
      </p>
      <ul class="max-w-prose space-y-3 mb-8 text-[18px] leading-[1.75] text-taipan-blue-400 list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> welche Aufgaben tatsächlich Wert schaffen,</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> wo Arbeit nur organisiert, dokumentiert oder kontrolliert wird</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> und wo operative Verantwortung sinnvoll vom System übernommen werden kann,</li>
      </ul>
      <p class="max-w-prose mb-5 text-[18px] leading-[1.75]">
        macht es Sinn, über Prozesse, Automatisierung und Tools zu sprechen.
      </p>
      <div class="pull-quote max-w-prose">
        <p>HubSpot ist dabei kein Ziel, sondern ein Mittel.</p>
      </div>
    </div>
  </section>

  <!-- Typ A – Weiß: Transformation -->
  <section class="section-a section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Wie wir Transformation verstehen</h2>
      <p class="text-body max-w-prose mb-8">
        Transformation bedeutet für uns nicht, bestehende Abläufe zu digitalisieren oder effizienter zu organisieren.
      </p>
      <p class="text-body max-w-prose mb-6">Transformation bedeutet:</p>
      <ul class="max-w-prose space-y-3 mb-8 text-body list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> Arbeit neu zu verteilen,</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> operative Last systematisch zu reduzieren</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> und Systeme so zu gestalten, dass sie Verantwortung übernehmen dürfen.</li>
      </ul>
      <p class="text-body max-w-prose">
        Das Ergebnis sind Prozesse, die nicht nur funktionieren, sondern im Alltag entlasten.
      </p>
    </div>
  </section>

  <!-- Typ C – Hell: Vorgehen -->
  <section class="section-c section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-8">Vorgehen in der Praxis</h2>
      <p class="text-body max-w-prose mb-8">
        Konkret arbeiten wir entlang weniger, klarer Schritte:
      </p>
      <ol class="max-w-prose space-y-6 mb-8 list-decimal list-inside text-body">
        <li>
          <span class="font-semibold text-taipan-blue-800">Klärung der aktuellen Arbeitslogik</span><br />
          <span class="text-taipan-gray-700">Nicht auf dem Papier, sondern im gelebten Alltag.</span>
        </li>
        <li>
          <span class="font-semibold text-taipan-blue-800">Definition zukunftsfähiger Prozesse</span><br />
          <span class="text-taipan-gray-700">Mit Blick auf Skalierbarkeit, Automatisierung und den Einsatz von KI.</span>
        </li>
        <li>
          <span class="font-semibold text-taipan-blue-800">Übersetzung in HubSpot</span><br />
          <span class="text-taipan-gray-700">Strukturen, Automatisierungen und Verantwortlichkeiten werden so abgebildet, dass sie Arbeit reduzieren – nicht verlagern.</span>
        </li>
        <li>
          <span class="font-semibold text-taipan-blue-800">Begleitung im Alltag</span><br />
          <span class="text-taipan-gray-700">Fokus auf Akzeptanz, Nutzung und reale Entlastung.</span>
        </li>
      </ol>
      <p class="text-body max-w-prose">
        Diese Schritte sind kein starres Modell, sondern ein Denkrahmen.
      </p>
    </div>
  </section>

  <!-- Typ A – Weiß: Was wir nicht tun -->
  <section class="section-a section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Was wir bewusst nicht tun</h2>
      <p class="text-body max-w-prose mb-8">
        Unser Ansatz bringt klare Abgrenzungen mit sich.
      </p>
      <p class="text-body max-w-prose mb-6">Wir:</p>
      <ul class="max-w-prose space-y-3 mb-8 text-body list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> liefern keine Standard-Setups,</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> optimieren keine isolierten Features,</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> implementieren keine Prozesse, die bestehende Probleme konservieren,</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> verkaufen keine Lösungen, bevor die zugrunde liegende Logik verstanden ist.</li>
      </ul>
      <p class="text-body max-w-prose">
        Wenn HubSpot lediglich bestehende Arbeitsweisen abbilden soll, sind wir nicht der richtige Partner.
      </p>
    </div>
  </section>

  <!-- Typ B – Dunkel: Rolle von HubSpot -->
  <section class="section-b section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Die Rolle von HubSpot</h2>
      <p class="max-w-prose mb-6 text-[18px] leading-[1.75]">
        In unserem Ansatz ist HubSpot eine <strong class="text-white">Arbeitsplattform</strong>, kein Projekt.
      </p>
      <p class="max-w-prose mb-8 text-[18px] leading-[1.75]">
        HubSpot wird dort wirksam,
      </p>
      <ul class="max-w-prose space-y-3 mb-8 text-[18px] leading-[1.75] text-taipan-blue-400 list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> wo Arbeit automatisiert oder zusammengeführt werden kann,</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> wo Status automatisch entsteht</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> und wo operative Aufgaben zuverlässig vom System übernommen werden.</li>
      </ul>
      <p class="max-w-prose mb-8 text-[18px] leading-[1.75]">
        Richtig eingesetzt unterstützt HubSpot Teams im Alltag –
        nicht durch Kontrolle, sondern durch Entlastung.
      </p>
      <a
        href="/#entlastung"
        class="text-[18px] font-medium text-taipan-blue-400 hover:text-taipan-blue-100 transition-colors underline underline-offset-2"
      >
        Welche operative Entlastung kannst du erwarten →
      </a>
    </div>
  </section>

  <!-- Typ C – Hell: Zusammenarbeit -->
  <section class="section-c section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-8">Zusammenarbeit</h2>
      <p class="text-body max-w-prose mb-6">
        Unsere Zusammenarbeit ist geprägt von:
      </p>
      <ul class="max-w-prose space-y-3 mb-8 text-body list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> Klarheit statt Versprechen,</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> Analyse statt Aktionismus</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> und gemeinsamer Verantwortung für Wirkung.</li>
      </ul>
      <p class="text-body max-w-prose">
        Wir arbeiten eng mit Führungskräften und operativen Teams,
        weil nachhaltige Entlastung nicht entschieden, sondern gelebt wird.
      </p>
    </div>
  </section>

  <!-- Typ A – Weiß: CTA -->
  <section id="kontakt" class="section-a section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <span class="label-overline mb-6 block">Nächster Schritt</span>
      <h2 class="max-w-3xl mb-6">
        Wenn du verstehen möchtest, ob dieser Ansatz zu deiner Situation passt, ist der nächste Schritt ein Gespräch.
      </h2>
      <p class="text-body max-w-prose mb-5">
        Kein Pitch.<br />
        Kein Angebot.<br />
        Sondern eine gemeinsame Einordnung.
      </p>
      <a
        href="mailto:fwl@taipanconsulting.de"
        class="h-12 px-8 inline-flex items-center bg-taipan-orange text-white rounded-md text-[16px] font-semibold hover:bg-taipan-orange-hover transition-colors duration-200"
      >
        Gespräch vereinbaren
      </a>
    </div>
  </section>
</BaseLayout>
