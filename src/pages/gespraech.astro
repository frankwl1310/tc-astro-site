---
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Startseite", "item": "https://taipanconsulting.de/" },
    { "@type": "ListItem", "position": 2, "name": "Gespräch", "item": "https://taipanconsulting.de/gespraech/" },
  ],
};

const contactPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Gespräch – Taipan Consulting",
  "description": "Kein Verkaufsgespräch. Ein Sparring, eine Standortbestimmung – mit dem Ziel zu klären, ob und wie HubSpot in deinem Kontext entlasten kann.",
  "url": "https://taipanconsulting.de/gespraech/",
  "isPartOf": { "@type": "WebSite", "name": "Taipan Consulting", "url": "https://taipanconsulting.de/" },
  "provider": {
    "@type": "ProfessionalService",
    "name": "Taipan Consulting GmbH",
    "url": "https://taipanconsulting.de",
    "telephone": "+496994322134",
    "email": "fwl@taipanconsulting.de",
  },
};
---
<BaseLayout
  title="Gespräch – Taipan Consulting"
  description="Kein Verkaufsgespräch. Ein Sparring, eine Standortbestimmung – mit dem Ziel zu klären, ob und wie HubSpot in deinem Kontext entlasten kann."
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(contactPageSchema)} />
  </Fragment>
  <!-- Typ A – Weiß: Hero -->
  <section class="section-a section-padding pt-28 pb-20 md:pt-32 md:pb-24">
    <div class="max-w-content mx-auto">
      <h1 class="max-w-3xl mb-6">Gespräch</h1>
      <p class="text-body max-w-prose mb-5 text-xl font-medium text-taipan-blue-800">
        Kein Verkaufsgespräch.<br />
        Sondern ein gemeinsames Nachdenken.
      </p>
      <p class="text-body max-w-prose mb-5">
        Wenn du dich in den beschriebenen Mustern auf dieser Seite wiedererkennst – rückblickend oder vorausschauend – ist der nächste Schritt kein Pitch und kein Angebot.
      </p>
      <p class="text-body max-w-prose mb-5">
        Es ist ein Gespräch.
      </p>
      <p class="text-body max-w-prose mb-5">
        Ein Sparring.<br />
        Eine Zweitmeinung.<br />
        Eine gemeinsame Standortbestimmung.
      </p>
      <p class="text-body max-w-prose">
        Mit dem Ziel zu klären, ob und wie HubSpot in deinem konkreten Kontext tatsächlich entlasten kann.
      </p>
    </div>
  </section>

  <!-- Typ B – Dunkel: Was dieses Gespräch ist -->
  <section class="section-b section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Was dieses Gespräch ist</h2>
      <ul class="max-w-prose space-y-3 mb-8 text-[18px] leading-[1.75] text-taipan-blue-400 list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> ein offener Austausch auf Augenhöhe</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> eine strukturierte Einordnung deiner Situation</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> ein Blick auf Arbeitsweisen, nicht auf Features</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> ehrlich, direkt und ohne Verkaufsagenda</li>
      </ul>
      <p class="max-w-prose mb-6 text-[18px] leading-[1.75]">
        Am Ende dieses Gesprächs ist klarer als vorher:
      </p>
      <ul class="max-w-prose space-y-3 text-[18px] leading-[1.75] text-taipan-blue-400 list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> wo du stehst</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> welche Annahmen tragen</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-400 mt-0.5 shrink-0">—</span> und ob ein gemeinsames Weiterarbeiten sinnvoll ist</li>
      </ul>
    </div>
  </section>

  <!-- Typ A – Weiß: Was dieses Gespräch nicht ist -->
  <section class="section-a section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Was dieses Gespräch nicht ist</h2>
      <ul class="max-w-prose space-y-3 mb-8 text-body list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> keine Produktdemo</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> kein Tool-Vergleich</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> kein Beratungspitch</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> kein vorbereiteter Lösungsbaukasten</li>
      </ul>
      <p class="text-body max-w-prose">
        Wenn du ein Angebot suchst, ohne die zugrunde liegende Arbeitslogik zu hinterfragen, ist dieses Gespräch nicht der richtige Rahmen.
      </p>
    </div>
  </section>

  <!-- Typ C – Hell: Wann sinnvoll / nicht sinnvoll -->
  <section class="section-c section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Wann dieses Gespräch sinnvoll ist</h2>
      <ul class="max-w-prose space-y-3 mb-10 text-body list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> HubSpot ist bereits eingeführt, aber entlastet nicht spürbar</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> HubSpot ist geplant und soll von Anfang an wirksam eingesetzt werden</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> operative Teams empfinden HubSpot eher als Aufwand denn als Hilfe</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> du willst verstehen, <strong>warum</strong> Dinge nicht greifen – nicht nur was</li>
      </ul>
      <h2 class="max-w-3xl mb-6">Wann dieses Gespräch nicht sinnvoll ist</h2>
      <ul class="max-w-prose space-y-3 mb-8 text-body list-none">
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> HubSpot soll „schnell umgesetzt“ werden</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> bestehende Prozesse sollen unverändert bleiben</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> Automatisierung soll primär Kontrolle erzeugen</li>
        <li class="flex items-start gap-3"><span class="text-taipan-blue-600 mt-0.5 shrink-0">—</span> ein konkretes Angebot steht bereits fest</li>
      </ul>
      <p class="text-body max-w-prose">
        Diese Klarheit spart Zeit – auf beiden Seiten.
      </p>
    </div>
  </section>

  <!-- Typ A – Weiß: Vorbereitung -->
  <section class="section-a section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Vorbereitung (optional)</h2>
      <p class="text-body max-w-prose mb-8">
        Damit das Gespräch für beide Seiten sinnvoll ist, hilft es, vorab über drei Fragen nachzudenken:
      </p>
      <ol class="max-w-prose space-y-4 mb-8 list-decimal list-inside text-body">
        <li>Wo kostet HubSpot heute im Alltag am meisten Zeit oder Energie?</li>
        <li>Welche Arbeit wird manuell erledigt, obwohl sie keinen direkten Mehrwert schafft?</li>
        <li>Woran würdest du merken, dass HubSpot wirklich entlastet?</li>
      </ol>
      <p class="text-body max-w-prose mb-5">
        Du musst diese Fragen nicht „fertig“ beantworten.
      </p>
      <p class="text-body max-w-prose">
        Es reicht, sie im Hinterkopf zu haben.
      </p>
    </div>
  </section>

  <!-- Typ B – Dunkel: Kontakt + CTA -->
  <section id="kontakt" class="section-b section-padding py-16 md:py-20">
    <div class="max-w-content mx-auto">
      <h2 class="max-w-3xl mb-6">Kontakt</h2>
      <p class="max-w-prose mb-8 text-[18px] leading-[1.75]">
        Wenn sich das für dich stimmig anfühlt, melde dich gerne.
      </p>
      <p class="max-w-prose mb-8 text-[18px] leading-[1.75]">
        Am einfachsten per E-Mail oder Telefon.
      </p>
      <p class="max-w-prose mb-10 text-[18px] leading-[1.75]">
        Wir klären dann gemeinsam, ob ein Gespräch sinnvoll ist – und in welchem Rahmen.
      </p>
      <a
        href="mailto:fwl@taipanconsulting.de"
        class="h-12 px-8 inline-flex items-center bg-taipan-orange text-white rounded-md text-[16px] font-semibold hover:bg-taipan-orange-hover transition-colors duration-200"
      >
        E-Mail schreiben
      </a>
      <p class="mt-6 text-[18px] leading-[1.75]">
        <a href="tel:+496994322134" class="text-taipan-blue-400 hover:text-taipan-blue-100 transition-colors">+49 69 94322134</a>
      </p>
    </div>
  </section>
</BaseLayout>
